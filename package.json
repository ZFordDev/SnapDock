{
  "name": "snapdock",
  "version": "3.1.1",
  "description": "a modern, Markdown editor with a clean UI and improved architecture.",
  "homepage": "https://github.com/ZFordDev/SnapDock",
  "author": "ZFordDev",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "electron .",

    "build:dev": "node scripts/build-dev.js",
    "build:test": "node scripts/build-test.js",
    "build:release": "node scripts/build-release.js",
    "build:linux": "node scripts/build-linux.js"
  },

  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "6.8.3",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.2.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-link-attributes": "^4.0.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-lists": "^2.1.1"
  },

  "devDependencies": {
    "electron": "42.3.3",
    "electron-builder": "^26.7.0",
    "esbuild": "^0.28.0",
    "rcedit": "^5.0.2"
  },

  "build": {
    "appId": "com.zforddev.snapdock",
    "productName": "SnapDock",
    "files": [
      "dist/**/*",
      "index.html",
      "src/**/*",
      "assets/**/*",
      "main.js",
      "src/preloads.js",
      "build/metadata.json"
    ],
    "artifactName": "SnapDock-${version}-${channel}-${os}-${arch}.${ext}",
    "win": {
      "icon": "assets/icon.ico",
      "target": ["nsis"]
    },
    "linux": {
      "icon": "assets/icons",
      "category": "Utility",
      "maintainer": "ZFordDev <zforddev@gmail.com>",
      "target": ["AppImage", "deb"]
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "assets/icon.icns",
      "target": ["dmg", "zip"]
    },

    "publish": [
      {
        "provider": "github",
        "owner": "ZFordDev",
        "repo": "SnapDock"
      }
    ]
  },
  "extraMetadata": {
    "buildStage": "active",
    "releaseDate": "2026-05-27"
  }
}

