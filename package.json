{
  "name": "snapdock",
  "version": "1.3.1",
  "description": "A powerful desktop markdown editor.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --dir",
    "pack": "electron-builder --win --linux",
    "build": "electron-builder"
  },
  "keywords": [
    "markdown",
    "editor",
    "electron"
  ],
  "author": "Zachary Ford",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.ZetoLabs.snapdock",
    "productName": "SnapDock",
    "copyright": "Copyright © 2025 ${author}",
    "directories": {
      "output": "dist"
    },
    "files": [
        "main.js",
              "preload.js",
              "index.html",
              "src/scripts.js",
              "src/styles.css",
              "src/fsHandler.js",
              "node_modules/",
              "markdown-it-master/",
              "version.json",
              "assets/icon.ico",
              "assets/logo.png",
              "assets/resources/**"
    ],
     "extraResources": [
      { "from": "src/filetree/pkg", "to": "filetree/pkg" }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": "nsis"
    }
  },
  "dependencies": {
    "markdown-it": "^14.1.0"
  }
}
